.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# Source Tableau workbooks may contain customer data - never commit
migrations/*/source/*.twb
migrations/*/source/*.twbx
migrations/*/source/*.hyper
migrations/*/data/

# Fabric/PBI build output can be regenerated - keep repo lean (comment out if you want to version it)
# migrations/*/fabric/

# Migration _work scratch - full-folder backups, Desktop screenshots, downloaded
# boundary files. The re-runnable *.py transform scripts in _work ARE tracked.
migrations/*/_work/backup-*/
migrations/*/_work/*.png
migrations/*/_work/*.geojson

# Build-time scratch renders (skeleton/actual comparison screenshots)
migrations/*/_scratch/
migrations/*/_build/

# .NET build output from the TMDL validation helper C# projects - regenerated by
# `dotnet build`; only the Program.cs / *.csproj source belongs in git.
[Bb]in/
[Oo]bj/

# Tableau Public harvester downloads + parsed specs (bulk .twbx + specs, transient
# corpus for parser stress-testing / hard-workbook selection - never commit).
/_harvest/
candidates.json

# Power BI Desktop local cache/settings - machine-specific, regenerated automatically on open
**/.pbi/cache.abf
**/.pbi/localSettings.json
**/.pbi/editorSettings.json

.env
.env.local
*.log

# Compiled/binary Power BI files - always commit the unpacked PBIP/TMDL/PBIR instead
*.pbix

# OS cruft
.DS_Store
Thumbs.db
