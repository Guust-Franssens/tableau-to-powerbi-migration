	/// Tableau 'IF [Latest Water Intake] > [Prior Water Intake] THEN [Latest Water Intake] - [Prior Water Intake] END' (positive-change branch; BLANK otherwise).
	measure 'Water Intake Diff +' = VAR _l = [Latest Water Intake] VAR _p = [Prior Water Intake] RETURN IF(_l > _p, _l - _p)
