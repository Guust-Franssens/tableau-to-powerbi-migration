		formatString: #,##0.0
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 97160522-6534-4c3b-a4b3-267e7bf12597

	/// Tableau 'IF [Latest Cal Bur] < [Prior Cal Bur] THEN [Latest Cal Bur] - [Prior Cal Bur] END' (negative-change branch; BLANK otherwise).
	measure 'Cal Bur Diff -' = VAR _l = [Latest Cal Bur] VAR _p = [Prior Cal Bur] RETURN IF(_l < _p, _l - _p)
		formatString: #,##0.0
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 5db641df-d4e6-466e-a1be-b0a37212abf7

	/// Tableau 'IF [Latest Cal Bur] = [Prior Cal Bur] THEN [Latest Cal Bur] - [Prior Cal Bur] END' (no-change branch; evaluates to 0 when equal, BLANK otherwise).
	measure 'Cal Bur No Diff' = VAR _l = [Latest Cal Bur] VAR _p = [Prior Cal Bur] RETURN IF(_l = _p, _l - _p)
		formatString: #,##0.0
