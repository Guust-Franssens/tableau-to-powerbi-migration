/// Daily personal-health fact table (730 rows, one row per calendar date 2022-01-01..2023-12-31). Source: Tableau data source 'ds.health_data' (extract-based .hyper, materialized to data/ds.health_data.csv per migration-spec limitations_encountered). Grain: one row per Date. All 12 metric columns kept visible with summarizeBy matching the Tableau-implied aggregation (sum for volume/count metrics, average for rate/score metrics) - the workbook exposed them as draggable measures.
table 'Health Data'
	lineageTag: acd7dfc3-c446-498e-8884-08c022c72623

	/// Max Date across the whole table, filter-independent (Tableau '{ MAX([Date]) }' implicit-FIXED LOD). Hidden helper referenced by every Latest/Prior measure. NOTE: parser did not flag the bare '{ MAX([Date]) }' as is_lod (only '{FIXED...}' detected) - see limitations_encountered.
	measure 'Latest Date' = CALCULATE(MAX('Health Data'[Date]), ALL('Health Data'))
		formatString: "Short Date"
		displayFolder: _Support
		isHidden
		lineageTag: bbb6ae0d-2e9d-4434-bba9-dead1bf1047d

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [BMI] END) }' - value of BMI on the max date, ignoring filter context.
	measure 'Latest BMI' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[BMI]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.00
		displayFolder: Latest (LOD)
		lineageTag: 2f23eda2-0faa-488d-bda0-d27aced8eaf6

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Calories Intake] END) }' - value of Calories Intake on the max date, ignoring filter context.
	measure 'Latest Cal Int' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Calories Intake]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: 995c901b-5bee-479a-8550-65c76d64c57e

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Calories Burned] END) }' - value of Calories Burned on the max date, ignoring filter context.
	measure 'Latest Cal Bur' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Calories Burned]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: 9c75ef98-2aa4-4a18-8962-d61f44ee829f

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Blood Pressure Systolic (mmHg)] END) }' - value of Blood Pressure Systolic (mmHg) on the max date, ignoring filter context.
	measure 'Latest BP Sys' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Blood Pressure Systolic (mmHg)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: 32f63d4c-42bd-4464-9213-d26173071ae4

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Mood Score (1-10)] END) }' - value of Mood Score (1-10) on the max date, ignoring filter context.
	measure 'Latest Mood Score' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Mood Score (1-10)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.00
		displayFolder: Latest (LOD)
		lineageTag: 2e34e819-80a2-49fc-83bd-14551870ff7b

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Blood Pressure Diastolic (mmHg)] END) }' - value of Blood Pressure Diastolic (mmHg) on the max date, ignoring filter context.
	measure 'Latest BP Dias' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Blood Pressure Diastolic (mmHg)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: c262c1aa-c97d-4ab3-82ef-1c2587de50fd

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Heart Rate (bpm)] END) }' - value of Heart Rate (bpm) on the max date, ignoring filter context.
	measure 'Latest HR bpm' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Heart Rate (bpm)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: e1adee62-de04-49a2-bb05-6d48d0c2d706

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Steps Count] END) }' - value of Steps Count on the max date, ignoring filter context.
	measure 'Latest Steps Count' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Steps Count]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Latest (LOD)
		lineageTag: b545c73f-a9b4-40d5-8478-299d708f8576

	/// Tableau FIXED-LOD '{ FIXED : AVERAGE(IF [Date]=[Latest Date] THEN [Sleep Duration (hours)] END) }' - value of Sleep Duration (hours) on the max date, ignoring filter context.
	measure 'Latest Sleep Dur' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Sleep Duration (hours)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.00
		displayFolder: Latest (LOD)
		lineageTag: ab8a0e66-848d-43d9-8adf-7124cc621c0a

	/// Tableau FIXED-LOD '{ FIXED : SUM(IF [Date]=[Latest Date] THEN [Water Intake (liters)] END) }' - value of Water Intake (liters) on the max date, ignoring filter context.
	measure 'Latest Water Intake' = VAR _d = [Latest Date] RETURN CALCULATE(SUM('Health Data'[Water Intake (liters)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.00
		displayFolder: Latest (LOD)
		lineageTag: c8f06874-a8ab-4871-a5c7-5c3b18cf10f9

	/// Tableau FIXED-LOD prior-period value of Calories Burned, period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Cal Bur' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(SUM('Health Data'[Calories Burned]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.0
		displayFolder: Prior (LOD)
		lineageTag: 921d4282-5548-4f50-b962-8585c7c32cde

	/// Tableau FIXED-LOD prior-period value of Calories Intake, period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Cal Int' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(SUM('Health Data'[Calories Intake]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.0
		displayFolder: Prior (LOD)
		lineageTag: b9b67fa5-1738-4e46-9f57-198d72d0d327

	/// Tableau FIXED-LOD prior-period value of Steps Count, period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Steps Count' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(SUM('Health Data'[Steps Count]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.0
		displayFolder: Prior (LOD)
		lineageTag: 3eedefb1-df44-4e42-ba89-7ea13eb8fc82

	/// Tableau FIXED-LOD prior-period value of Mood Score (1-10), period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Mood Score' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(AVERAGE('Health Data'[Mood Score (1-10)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.00
		displayFolder: Prior (LOD)
		lineageTag: b1d8523d-797e-40bb-9377-74d070b9aa50

	/// Tableau FIXED-LOD prior-period value of Sleep Duration (hours), period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Sleep Dur' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(AVERAGE('Health Data'[Sleep Duration (hours)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.00
		displayFolder: Prior (LOD)
		lineageTag: c83ea0fa-77cc-4782-a548-cabcdb6585ec

	/// Tableau FIXED-LOD prior-period value of Water Intake (liters), period chosen by the 'Date Period' parameter (Last Week=maxDate-7, Last Month=EDATE(-1), Last Year=EDATE(-12)). Prior Week/Month/Year date fields inlined into _p.
	measure 'Prior Water Intake' = VAR _sel = [Date Period Value] VAR _max = [Latest Date] VAR _p = SWITCH(_sel, "Last Week", _max - 7, "Last Month", EDATE(_max, -1), "Last Year", EDATE(_max, -12), _max - 7) RETURN CALCULATE(AVERAGE('Health Data'[Water Intake (liters)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _p))
		formatString: #,##0.00
		displayFolder: Prior (LOD)
		lineageTag: ca603b85-cb41-43e1-a0cd-6fd0e26429af

	/// Tableau 'IF [Latest Cal Int] > [Prior Cal Int] THEN [Latest Cal Int] - [Prior Cal Int] END' (positive-change branch; BLANK otherwise).
	measure 'Cal Int Diff +' = VAR _l = [Latest Cal Int] VAR _p = [Prior Cal Int] RETURN IF(_l > _p, _l - _p)
		formatString: #,##0.0
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 3cab4bb6-1aef-4b85-9b21-337f55e7d9bc

	/// Tableau 'IF [Latest Cal Int] < [Prior Cal Int] THEN [Latest Cal Int] - [Prior Cal Int] END' (negative-change branch; BLANK otherwise).
	measure 'Cal Int Diff -' = VAR _l = [Latest Cal Int] VAR _p = [Prior Cal Int] RETURN IF(_l < _p, _l - _p)
		formatString: #,##0.0
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 4cea6590-7228-4350-8ba1-c89852f1ff70

	/// Tableau 'IF [Latest Cal Int] = [Prior Cal Int] THEN [Latest Cal Int] - [Prior Cal Int] END' (no-change branch; evaluates to 0 when equal, BLANK otherwise).
	measure 'Cal Int No Diff' = VAR _l = [Latest Cal Int] VAR _p = [Prior Cal Int] RETURN IF(_l = _p, _l - _p)
		formatString: #,##0.0
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 00c30c12-8e03-4f97-89c7-c35de47a4c6d

	/// Tableau 'IF [Latest Cal Bur] > [Prior Cal Bur] THEN [Latest Cal Bur] - [Prior Cal Bur] END' (positive-change branch; BLANK otherwise).
