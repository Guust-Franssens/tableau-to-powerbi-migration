	/// Tableau 'IF [Latest Mood Score] = [Prior Mood Score] THEN [Latest Mood Score] - [Prior Mood Score] END' (no-change branch; evaluates to 0 when equal, BLANK otherwise).
	measure 'Mood Score No Diff' = VAR _l = [Latest Mood Score] VAR _p = [Prior Mood Score] RETURN IF(_l = _p, _l - _p)
