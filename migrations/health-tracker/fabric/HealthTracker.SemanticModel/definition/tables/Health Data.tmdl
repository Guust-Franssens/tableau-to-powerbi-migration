	/// Tableau 'IF [Latest Water Intake] < [Prior Water Intake] THEN [Latest Water Intake] - [Prior Water Intake] END' (negative-change branch; BLANK otherwise).
	measure 'Water Intake Diff -' = VAR _l = [Latest Water Intake] VAR _p = [Prior Water Intake] RETURN IF(_l < _p, _l - _p)
		formatString: #,##0.00
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 015c2b4e-eb67-4d50-83e4-5f4255a63c56

	/// Tableau 'IF [Latest Water Intake] = [Prior Water Intake] THEN [Latest Water Intake] - [Prior Water Intake] END' (no-change branch; evaluates to 0 when equal, BLANK otherwise).
	measure 'Water Intake No Diff' = VAR _l = [Latest Water Intake] VAR _p = [Prior Water Intake] RETURN IF(_l = _p, _l - _p)
		formatString: #,##0.00
		displayFolder: Diff (Latest vs Prior)
		lineageTag: 1d9ea7bb-8800-4e77-83e6-a31b7d2d1210

	/// Tableau BMI category IF/ELSEIF on [Latest BMI]. WHO-style bands: <=18.4 Underweight, <=24.9 Normal weight, else Overweight.
	measure 'BMI text' = VAR _v = [Latest BMI] RETURN SWITCH(TRUE(), _v <= 18.4, "Underweight", _v <= 24.9, "Normal weight", "Overweight")
		displayFolder: Status Text
		lineageTag: 6febe980-319d-4f4a-b6c0-e9b6321ff98c

	/// Tableau heart-rate category on [Latest HR bpm]. Final 'Invalid Heart Rate' ELSE is unreachable for any real number - translated faithfully (source-workbook dead branch).
	measure 'HR text' = VAR _v = [Latest HR bpm] RETURN SWITCH(TRUE(), _v < 60, "Low Heart Rate", _v <= 100, "Normal Heart Rate", _v > 100, "High Heart Rate", "Invalid Heart Rate")
		displayFolder: Status Text
		lineageTag: 870ad8e5-5656-4d55-8ee7-5db5a52cfb7b

	/// Tableau AHA blood-pressure category on [Latest BP Sys]/[Latest BP Dias]. Chained compound IF/ELSEIF -> SWITCH(TRUE()).
	measure 'BP text' = VAR _sys = [Latest BP Sys] VAR _dias = [Latest BP Dias] RETURN SWITCH(TRUE(), _sys <= 120 && _dias <= 80, "Normal Blood Pressure", _sys <= 129 && _dias < 80, "Elevated Blood Pressure", (_sys <= 139 && _sys >= 130) || (_dias <= 89 && _dias >= 80), "Stage 1 Hypertension", (_sys <= 180 && _sys >= 140) || (_dias <= 120 && _dias >= 90), "Stage 2 Hypertension", "Hypertensive Crisis - Consult a Doctor Immediately")
		displayFolder: Status Text
		lineageTag: ec9ba34d-eb9e-4432-b6e9-9f21d13fab70

	/// Translation of the Tableau boolean 'Date Period' filter field (renamed to avoid collision with the 'Date Period' slicer table/column). 1 when the current context rows fall in the parameter-selected latest period, else 0. Use as a visual-level filter (=1). NOTE: a measure filter restricts categories not rows - see limitations_encountered for the report-layer row-restriction guidance.
	measure 'In Selected Period' = VAR _sel = [Date Period Value] VAR _w = MAXX('Health Data', IF('Health Data'[Latest Week], 1, 0)) VAR _m = MAXX('Health Data', IF('Health Data'[Latest Month], 1, 0)) VAR _y = MAXX('Health Data', IF('Health Data'[Latest Year], 1, 0)) RETURN SWITCH(_sel, "Last Week", _w, "Last Month", _m, "Last Year", _y, _w)
		formatString: 0
		displayFolder: Period Support
		lineageTag: ba49bfce-4a17-4dd2-8d46-8703957d7ca7

	/// Translation of the Tableau boolean 'Date Color' color-encoding field (Last Week/Last Month -> Latest Day; Last Year -> Latest Month). 1 highlights the latest bar. Absorbs the Tableau 'Label' field (IF [Date Color] THEN 'Yes') - report shows the data label where Highlight Latest = 1.
	measure 'Highlight Latest' = VAR _sel = [Date Period Value] VAR _d = MAXX('Health Data', IF('Health Data'[Latest Day], 1, 0)) VAR _m = MAXX('Health Data', IF('Health Data'[Latest Month], 1, 0)) RETURN SWITCH(_sel, "Last Week", _d, "Last Month", _d, "Last Year", _m, _d)
		formatString: 0
		displayFolder: Period Support
		lineageTag: 449238d0-80c2-445a-b14d-3d40f38fc657

	/// Report-layer KPI delta = Latest - Prior for Calories Burned (period per 'Date Period' page filter). +/- sign section conveys direction (red/green color simplified out - see report limitations); collapses the Tableau Diff+/Diff-/No Diff split into one signed card.
	measure 'Cal Bur Delta' = [Latest Cal Bur] - [Prior Cal Bur]
		formatString: "+#,##0.0;-#,##0.0;0.0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0001-4a10-9e01-0a1b2c3d4e01

	/// Report-layer KPI delta = Latest - Prior for Calories Intake (period per 'Date Period' page filter).
	measure 'Cal Int Delta' = [Latest Cal Int] - [Prior Cal Int]
		formatString: "+#,##0.0;-#,##0.0;0.0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0002-4a10-9e01-0a1b2c3d4e02

	/// Report-layer KPI delta = Latest - Prior for Steps Count (period per 'Date Period' page filter).
	measure 'Steps Count Delta' = [Latest Steps Count] - [Prior Steps Count]
		formatString: "+#,##0;-#,##0;0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0003-4a10-9e01-0a1b2c3d4e03

	/// Report-layer KPI delta = Latest - Prior for Sleep Duration (period per 'Date Period' page filter).
	measure 'Sleep Duration Delta' = [Latest Sleep Dur] - [Prior Sleep Dur]
		formatString: "+#,##0.0;-#,##0.0;0.0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0004-4a10-9e01-0a1b2c3d4e04

	/// Report-layer KPI delta = Latest - Prior for Mood Score (period per 'Date Period' page filter).
	measure 'Mood Score Delta' = [Latest Mood Score] - [Prior Mood Score]
		formatString: "+#,##0.0;-#,##0.0;0.0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0005-4a10-9e01-0a1b2c3d4e05

	/// Report-layer KPI delta = Latest - Prior for Water Intake (period per 'Date Period' page filter).
	measure 'Water Intake Delta' = [Latest Water Intake] - [Prior Water Intake]
		formatString: "+#,##0.0;-#,##0.0;0.0"
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0006-4a10-9e01-0a1b2c3d4e06

	/// Latest-day Height (cm) LOD helper (mirrors the Latest BMI/etc. pattern) - header 'Current Height' card.
	measure 'Latest Height' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Height (cm)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0007-4a10-9e01-0a1b2c3d4e07

	/// Latest-day Weight (kg) LOD helper (mirrors the Latest BMI/etc. pattern) - header 'Current Weight' card.
	measure 'Latest Weight' = VAR _d = [Latest Date] RETURN CALCULATE(AVERAGE('Health Data'[Weight (kg)]), FILTER(ALL('Health Data'), 'Health Data'[Date] = _d))
		formatString: #,##0.0
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0008-4a10-9e01-0a1b2c3d4e08

	/// Combined 'systolic / diastolic' text for the Blood Pressure KPI card (e.g. '101 / 86').
	measure 'Latest BP Combined' = FORMAT(ROUND([Latest BP Sys], 0), "0") & " / " & FORMAT(ROUND([Latest BP Dias], 0), "0")
		displayFolder: Report Support
		lineageTag: 1a2b3c40-0009-4a10-9e01-0a1b2c3d4e09

	/// Calendar date, one row per day (Tableau dimension 'Date'). Drives all Latest/Prior LOD date logic.
	column 'Date'
		dataType: dateTime
		formatString: "Short Date"
		lineageTag: ba2bee9f-2c51-45f5-af69-a6dfd8b05a90
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

