	/// Tableau boolean 'Latest Day' = DATETRUNC('day',[Date]) = DATEADD('day',-1,DATETRUNC('day',{MAX([Date])}+1)). Reduces to [Date] = max date. Row-level, filter-independent.
	column 'Latest Day' = 'Health Data'[Date] = MAXX(ALL('Health Data'), 'Health Data'[Date])
		dataType: boolean
		lineageTag: 7acec83c-6790-4bb8-ae8f-e1310f3e7e1b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau boolean 'Latest Week' - the trailing 7 days ending AT maxDate (inclusive). For maxDate 2023-12-31 that is Dec 25-31, so the max date IS included and the week-page 'Highlight Latest' (which targets the max date via Latest Day) resolves to a visible bar.
	column 'Latest Week' = VAR _max = MAXX(ALL('Health Data'), 'Health Data'[Date]) RETURN 'Health Data'[Date] > _max - 7 && 'Health Data'[Date] <= _max
		dataType: boolean
		lineageTag: 81f35b08-e466-4ce9-a734-0e631efec8c3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau boolean 'Latest Month' - month before the month containing maxDate+1. For maxDate 2023-12-31 that is Dec 2023 (includes maxDate).
	column 'Latest Month' = VAR _max = MAXX(ALL('Health Data'), 'Health Data'[Date]) VAR _target = EDATE(DATE(YEAR(_max + 1), MONTH(_max + 1), 1), -1) VAR _ms = DATE(YEAR('Health Data'[Date]), MONTH('Health Data'[Date]), 1) RETURN _ms = _target
		dataType: boolean
		lineageTag: d33b687d-c7de-45e7-be58-9c0b675e9a6b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau boolean 'Latest Year' - year before the year containing maxDate+1. For maxDate 2023-12-31 that is 2023 (includes maxDate).
	column 'Latest Year' = VAR _max = MAXX(ALL('Health Data'), 'Health Data'[Date]) VAR _target = DATE(YEAR(_max + 1) - 1, 1, 1) VAR _ys = DATE(YEAR('Health Data'[Date]), 1, 1) RETURN _ys = _target
		dataType: boolean
		lineageTag: 1f7f2fe0-5244-4fd7-a253-df28fe5ae786
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Day-of-month 1-31 (Tableau 'Date period selected' DATENAME('day',[Date]) for the Last Week / Last Month axis). Report binds this as the trend-bar axis for the day-grain periods.
	column 'Day Of Month' = DAY('Health Data'[Date])
		dataType: int64
		formatString: 0
		lineageTag: 28d323b5-8d0b-4612-93d4-436d53c52368
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Hidden sort helper (1-12) for 'Month Name'.
	column 'Month Number' = MONTH('Health Data'[Date])
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 20c71043-fa54-4ee7-93bb-4621768b8580
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Full month name (Tableau 'Date period selected' DATENAME('month',[Date]) for the Last Year axis). Consolidates the Tableau 'Date period selected name' field (UPPER(month name)) - the report uppercases at the visual level.
	column 'Month Name' = FORMAT('Health Data'[Date], "MMMM")
		dataType: string
		lineageTag: 03419a8d-dce6-4e62-8ecb-15d60e1c9820
		summarizeBy: none
		sortByColumn: 'Month Number'

		annotation SummarizationSetBy = Automatic

	partition 'Health Data' = m
		mode: import
		source =
				let
					Source = Csv.Document(File.Contents(DataFolder & "ds.health_data.csv"),[Delimiter=",", Columns=13, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
					#"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
					#"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"Date", type date}, {"Weight (kg)", type number}, {"Height (cm)", type number}, {"BMI", type number}, {"Calories Intake", type number}, {"Calories Burned", type number}, {"Sleep Duration (hours)", type number}, {"Steps Count", type number}, {"Heart Rate (bpm)", type number}, {"Blood Pressure Systolic (mmHg)", type number}, {"Blood Pressure Diastolic (mmHg)", type number}, {"Mood Score (1-10)", type number}, {"Water Intake (liters)", type number}}, "en-US")
				in
					#"Changed Type"

	annotation PBI_ResultType = Table
