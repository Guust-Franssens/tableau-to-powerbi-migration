/// City-grain dimension + pre-computed indicator table (906 cities, one row per city). Source: Tableau data source 'UA_cities_tableau_all_05122018' (extract-based .hyper). Primary key: Name.
table 'UA Cities'
	lineageTag: 500bbae2-29c9-4e17-9949-5c76bd521f9e

	/// Row count for the UA Cities table (Tableau 'Number of Records' calculated field, formula: 1)
	measure 'Number of Records (UA Cities)' = COUNTROWS('UA Cities')
		formatString: #,##0
		lineageTag: 67e46b07-ee9d-4a8c-84bb-a935ac76b8a5

	/// Gauge value for the 'Cdd 0 1' scatter-point worksheet: raw 0-1 index rescaled to the -5..105 reference-line axis used by the original Tableau worksheet (SUM(['CDD_0_1']) * 100).
	measure 'Cdd 0 1 Value' = SUM('UA Cities'[Cdd 0 1]) * 100
		formatString: #,##0.0
		displayFolder: Gauge Support
		lineageTag: c56c3473-db43-4310-8bcb-45a713af2866

	/// Gauge minimum (Tableau reference line 'Min'/'Decrease', constant -5)
	measure 'Cdd 0 1 Min' = -5
		formatString: #,##0
		displayFolder: Gauge Support
		lineageTag: e76baa6b-659b-40f8-9139-c605944bafc7

	/// Gauge maximum (Tableau reference line 'Max'/'Increase', constant 105)
	measure 'Cdd 0 1 Max' = 105
		formatString: #,##0
		displayFolder: Gauge Support
		lineageTag: 79af43ad-12d6-466a-b729-d237a30b7ab4

	/// Gauge target (Average reference line, constant 50)
