	/// Adaptation text: row-level narrative built from Name / Initiative / EU project; blank when no initiative is recorded. 1:1 translation of the Tableau IF ISNULL([initiative]) calculated field. Fixed to treat empty-string Initiative (post-CSV-import artifact of Tableau NULL) as blank, matching Tableau's ISNULL semantics.
	column 'Adaptation Text' = IF(ISBLANK('UA Cities'[Initiative]) || 'UA Cities'[Initiative] = "", "", 'UA Cities'[Name] & " " & 'UA Cities'[Initiative] & " has participated in the following recent EU-funded projects on adaptation: " & 'UA Cities'[EU project])
		dataType: string
		lineageTag: e209abaf-f845-4bd5-8c1e-5d8b9f290e5b
		summarizeBy: none

	/// Dynamic parragraph: multi-line narrative combining RAMSES cluster/description and RESIN group fields. Row grain is one row per city, so Tableau's ATTR() collapses to a plain column reference (guide sec. "ATTR()"). Caption/typo ("parragraph") kept verbatim from the source workbook.
	column 'Dynamic parragraph' = "According to RAMSES project (l) the city is in cluster " & 'UA Cities'[RAMSES cluster] & " " & 'UA Cities'[RAMSES description] & UNICHAR(10) & UNICHAR(10) & "According to the RESIN project (m), the city belongs to the group " & 'UA Cities'[RESIN group name] & ", which includes " & 'UA Cities'[RESIN group description] & "." & UNICHAR(10) & UNICHAR(10) & "Cities of similar size " & 'UA Cities'[Population Brackets] & " in the group " & 'UA Cities'[RESIN group name] & "  are " & 'UA Cities'[Cities In Group] & "."
		dataType: string
		lineageTag: 3eb6d5cb-0c56-42b4-8b95-d7053743d719
		summarizeBy: none

