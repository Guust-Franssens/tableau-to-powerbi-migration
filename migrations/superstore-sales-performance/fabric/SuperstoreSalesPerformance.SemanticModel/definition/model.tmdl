model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Sample Superstore","Date","TOC Annotations","Insights","Region Parameter","Date Comparison","Minimum Date","Maximum Date","DataFolder"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table 'Sample Superstore'
ref table Date
ref table 'TOC Annotations'
ref table Insights
ref table 'Region Parameter'
ref table 'Date Comparison'
ref table 'Minimum Date'
ref table 'Maximum Date'
ref table Y-Axis
ref table X-Axis
ref table 'Map KPI'
ref table 'Scatter Plot Detail'
ref table 'Date Granularity'

