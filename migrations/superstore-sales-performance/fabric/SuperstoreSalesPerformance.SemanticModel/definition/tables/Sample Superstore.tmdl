	/// Tableau 'Order Date 2017' calculated column = [Order Date] + 365, a static +365-day forward shift applied to every row so 2013-2016 sample data displays as if the "current" year were 2017-2018 in the parameter UI - a known Tableau-sample-data convention, not a bug. This shifted date (not the raw Order Date) is the key used in the relationship to the 'Date' table, since the Minimum/Maximum Date parameters are calibrated to this shifted timeline (default window 2016-09-01 to 2017-03-31 falls inside the shifted range).
	column 'Order Date 2017' = 'Sample Superstore'[Order Date] + 365
		dataType: dateTime
		formatString: Short Date
		lineageTag: b563d03b-01c0-4914-af1d-cd1e9e33eb35
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau 'Days to Ship' calculated column = [Ship Date] - [Order Date], an integer day count. No parameter dependency, so implemented as a calculated column (the CP Days To Ship / PP Days To Ship measures average it with the date-window + region restriction).
	column 'Days to Ship' = INT('Sample Superstore'[Ship Date] - 'Sample Superstore'[Order Date])
		dataType: int64
		formatString: #,##0
		lineageTag: ed950a0c-c58b-4271-8f8f-1c988f1fb9c5
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau 'Region Abbreviation' calculated column = LEFT([Region],1), e.g. "C"/"E"/"S"/"W". No parameter dependency, so implemented as a calculated column. Used as the Label text on the 3 Region Comp dot-plots.
	column 'Region Abbreviation' = LEFT('Sample Superstore'[Region], 1)
		dataType: string
		lineageTag: 691a01e7-1431-4990-9ad1-a9819ae5d81e
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

