	/// Calendar days between order and shipment (Ship Date minus Order Date); row-level integer. From Tableau [Days to Ship].
	column 'Days to Ship' = DATEDIFF('Orders'[Order Date], 'Orders'[Ship Date], DAY)
		dataType: int64
		formatString: #,##0
		lineageTag: 6482414f-15d1-5616-92f2-9f2d03eee1e7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Whether the line shipped within its ship-mode SLA (Same Day 0d, First Class 2d, Second Class 4d, Standard Class 5d); row-level TRUE/FALSE. From Tableau [On Time Ship?].
	column 'On Time Ship?' = ('Orders'[Ship Mode] = "Same Day" && 'Orders'[Days to Ship] = 0) || ('Orders'[Ship Mode] = "First Class" && 'Orders'[Days to Ship] <= 2) || ('Orders'[Ship Mode] = "Second Class" && 'Orders'[Days to Ship] <= 4) || ('Orders'[Ship Mode] = "Standard Class" && 'Orders'[Days to Ship] <= 5)
		dataType: boolean
		lineageTag: 56815a98-eab2-58d7-af33-923ed74b83f4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Ship Date truncated to the first of its month (month grain); hidden helper axis the Sales window table-calcs address over. Tableau tmn:Ship Date axis.
	column 'Ship Month' = DATE(YEAR('Orders'[Ship Date]), MONTH('Orders'[Ship Date]), 1)
		dataType: dateTime
		formatString: Long Date
		lineageTag: 53281acc-003e-56f0-8ca1-06a1cb864a4a
		summarizeBy: none
		isHidden

		annotation SummarizationSetBy = Automatic

	/// Order Date truncated to the first of its quarter (quarter grain); hidden helper axis the East/West and 5th/6th-axis window table-calcs address over. Tableau tqr:Order Date axis.
	column 'Order Quarter' = DATE(YEAR('Orders'[Order Date]), (QUARTER('Orders'[Order Date]) - 1) * 3 + 1, 1)
		dataType: dateTime
		formatString: Long Date
		lineageTag: 95c7b270-2225-5100-870b-f21a31718926
		summarizeBy: none
		isHidden

		annotation SummarizationSetBy = Automatic

	partition 'Orders' = m
		mode: import
		source =
				let
				    Source = Csv.Document(File.Contents(DataFolder & "ds.orders_sample_superstore.csv"), [Delimiter=",", Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
