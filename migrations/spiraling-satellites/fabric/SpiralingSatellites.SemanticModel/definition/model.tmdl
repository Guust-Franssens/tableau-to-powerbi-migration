model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Orders","Model","City","Spiral","DataFolder"]

annotation __PBI_TimeIntelligenceEnabled = 0

ref table Orders
ref table Model
ref table City
ref table Spiral

