		formatString: 0.0%
		displayFolder: Prior Month (PM)

	/// Tableau 'PM No of Comp Flights' measure. No of Comp Flights over PM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM No of Comp Flights' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
