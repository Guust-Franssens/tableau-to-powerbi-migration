/// Flight-leg grain fact table (246,236 rows; one row per scheduled flight leg per date). Source: Tableau data source 'airline_alliance_performance_2022_2025' (the '_1' extract; the near-duplicate non-suffixed source is vestigial - 0 worksheet bindings - see limitations_encountered). Hosts all period-comparison KPI measures.
table 'Flight Activity'

	/// Tableau 'CY All Flights' measure. All Flights over CY period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY All Flights' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_year_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Current Year (CY)

	/// Tableau 'CY Avg. CSAT' measure. Avg. CSAT over CY period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY Avg. CSAT' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(AVERAGE('Flight Activity'[Customer Satisfaction Score]),'Flight Activity'[Year]=_m_year_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: 0.00
		displayFolder: Current Year (CY)

	/// Tableau 'CY CTK' measure. CTK over CY period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY CTK' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUMX('Flight Activity','Flight Activity'[Cargo Carried Kg]*'Flight Activity'[Distance Km])/1000,'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Current Year (CY)

	/// Tableau 'CY Cargo Load Factor' measure. Cargo Load Factor over CY period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY Cargo Load Factor' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(AVERAGE('Flight Activity'[Cargo Load Factor]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: 0.0%
		displayFolder: Current Year (CY)

	/// Tableau 'CY Costs' measure. Costs over CY period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY Costs' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Total Costs Usd]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: \$#,##0
		displayFolder: Current Year (CY)

	/// Tableau 'CY Count On-Time Perf' measure. Count On-Time Perf over CY period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'CY Count On-Time Perf' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[On Time Performance]=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
