	/// Tableau 'PM Op Profit' measure. Op Profit over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Op Profit' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Operating Profit Usd]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: \$#,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Passenger Count' measure. Passenger Count over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Passenger Count' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Passengers Carried]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM RPK' measure. RPK over PM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM RPK' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUMX('Flight Activity','Flight Activity'[Passengers Carried]*'Flight Activity'[Distance Km]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM RPK (A)' measure. RPK (A) over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM RPK (A)' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUMX('Flight Activity','Flight Activity'[Passengers Carried]*'Flight Activity'[Distance Km]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Total Revenue' measure. Total Revenue over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Total Revenue' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Total Revenue Usd]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: \$#,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'CY On-Time Perf%': CY on-time flights / CY all flights.
	measure 'CY On-Time Perf%' = DIVIDE([CY Count On-Time Perf],[CY All Flights])
		formatString: 0.0%
		displayFolder: Ratios

	/// Tableau 'CM On-Time Perf%': CM on-time flights / CM all flights.
	measure 'CM On-Time Perf%' = DIVIDE([CM Count On-Time Perf],[CM All Flights])
		formatString: 0.0%
		displayFolder: Ratios

	/// Tableau 'PM On-Time Perf %': PM on-time flights / PM all flights.
	measure 'PM On-Time Perf %' = DIVIDE([PM Count On-Time Perf],[PM All Flights])
		formatString: 0.0%
		displayFolder: Ratios

	/// Tableau 'CM % of Mishandled Baggage': CM mishandled-baggage flights / CM completed flights.
	measure 'CM % of Mishandled Baggage' = DIVIDE([CM No of Mishandled Baggage],[CM No of Comp Flights])
		formatString: 0.0%
		displayFolder: Ratios

	/// Tableau 'PM % of Mishandled Baggage'. NOTE: denominator is CM (not PM) No of Comp Flights - faithful reproduction of a source-workbook quirk (see limitations_encountered).
	measure 'PM % of Mishandled Baggage' = DIVIDE([PM No of Mishandled Baggage],[CM No of Comp Flights])
		formatString: 0.0%
		displayFolder: Ratios

	/// Tableau 'Passenger Count Circle Col': YoY direction (Up/Down/No) of CY Passenger Count vs PY Passenger Count.
	measure 'Passenger Count Circle Col' = IF([CY Passenger Count]>[PY Passenger Count],"Up",IF([CY Passenger Count]<[PY Passenger Count],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Total Revenue Circle Col': YoY direction (Up/Down/No) of CY Total Revenue vs PY Total Revenue.
	measure 'Total Revenue Circle Col' = IF([CY Total Revenue]>[PY Total Revenue],"Up",IF([CY Total Revenue]<[PY Total Revenue],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Op Profit Circle Col': YoY direction (Up/Down/No) of CY Op Profit vs PY Op Profit.
	measure 'Op Profit Circle Col' = IF([CY Op Profit]>[PY Op Profit],"Up",IF([CY Op Profit]<[PY Op Profit],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Costs Circle Col': YoY direction (Up/Down/No) of CY Op Profit vs PY Op Profit. NOTE: source formula compares CY/PY Op Profit (not Costs) - faithful reproduction of a source quirk.
	measure 'Costs Circle Col' = IF([CY Op Profit]>[PY Op Profit],"Up",IF([CY Op Profit]<[PY Op Profit],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Load Factor Circle Col': YoY direction (Up/Down/No) of CY Load Factor vs PY Load Factor.
	measure 'Load Factor Circle Col' = IF([CY Load Factor]>[PY Load Factor],"Up",IF([CY Load Factor]<[PY Load Factor],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Cargo Load Factor Circle Col': YoY direction (Up/Down/No) of CY Cargo Load Factor vs PY Cargo Load Factor.
	measure 'Cargo Load Factor Circle Col' = IF([CY Cargo Load Factor]>[PY Cargo Load Factor],"Up",IF([CY Cargo Load Factor]<[PY Cargo Load Factor],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'CTK Circle Col': YoY direction (Up/Down/No) of CY CTK vs PY CTK.
	measure 'CTK Circle Col' = IF([CY CTK]>[PY CTK],"Up",IF([CY CTK]<[PY CTK],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Freight Tonnes Circle Col': YoY direction (Up/Down/No) of CY Freight Tonnes vs PY Freight Tonnes.
	measure 'Freight Tonnes Circle Col' = IF([CY Freight Tonnes]>[PY Freight Tonnes],"Up",IF([CY Freight Tonnes]<[PY Freight Tonnes],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'RPK Perf Circle Col': YoY direction (Up/Down/No) of CY RPK vs PY RPK.
	measure 'RPK Perf Circle Col' = IF([CY RPK]>[PY RPK],"Up",IF([CY RPK]<[PY RPK],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'RPK Perf Circle Col (A)': YoY direction (Up/Down/No) of CY RPK (A) vs PY RPK (A).
	measure 'RPK Perf Circle Col (A)' = IF([CY RPK (A)]>[PY RPK (A)],"Up",IF([CY RPK (A)]<[PY RPK (A)],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Comp Flights Circle Col': YoY direction (Up/Down/No) of CY No of Comp Flights vs PY No of Comp Flights.
	measure 'Comp Flights Circle Col' = IF([CY No of Comp Flights]>[PY No of Comp Flights],"Up",IF([CY No of Comp Flights]<[PY No of Comp Flights],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'On-Time Perf Circle Col': YoY direction (Up/Down/No) of CY Count On-Time Perf vs PY Count On-Time Perf. Compares raw CY/PY on-time flight COUNT (not the %).
	measure 'On-Time Perf Circle Col' = IF([CY Count On-Time Perf]>[PY Count On-Time Perf],"Up",IF([CY Count On-Time Perf]<[PY Count On-Time Perf],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'CSAT Perf Circle Col': YoY direction (Up/Down/No) of CY Avg. CSAT vs PY Avg. CSAT.
	measure 'CSAT Perf Circle Col' = IF([CY Avg. CSAT]>[PY Avg. CSAT],"Up",IF([CY Avg. CSAT]<[PY Avg. CSAT],"Down","No"))
		displayFolder: Trend Indicators (YoY)

	/// Tableau 'Pos MoM Passenger Count': month-over-month growth (CM Passenger Count/PM Passenger Count - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Passenger Count' = IF([PM Passenger Count]<>0,DIVIDE([CM Passenger Count],[PM Passenger Count])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Total Revenue': month-over-month growth (CM Total Revenue/PM Total Revenue - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Total Revenue' = IF([PM Total Revenue]<>0,DIVIDE([CM Total Revenue],[PM Total Revenue])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Op Profit': month-over-month growth (CM Op Profit/PM Op Profit - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Op Profit' = IF([PM Op Profit]<>0,DIVIDE([CM Op Profit],[PM Op Profit])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Costs': month-over-month growth (CM Costs/PM Costs - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Costs' = IF([PM Costs]<>0,DIVIDE([CM Costs],[PM Costs])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Load Factor': month-over-month growth (CM Load Factor/PM Load Factor - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Load Factor' = IF([PM Load Factor]<>0,DIVIDE([CM Load Factor],[PM Load Factor])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Cargo Load Factor': month-over-month growth (CM Cargo Load Factor/PM Cargo Load Factor - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Cargo Load Factor' = IF([PM Cargo Load Factor]<>0,DIVIDE([CM Cargo Load Factor],[PM Cargo Load Factor])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM CTK': month-over-month growth (CM CTK/PM CTK - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM CTK' = IF([PM CTK]<>0,DIVIDE([CM CTK],[PM CTK])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Freight Tonnes': month-over-month growth (CM Freight Tonnes/PM Freight Tonnes - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Freight Tonnes' = IF([PM Freight Tonnes]<>0,DIVIDE([CM Freight Tonnes],[PM Freight Tonnes])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM RPK': month-over-month growth (CM RPK/PM RPK - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM RPK' = IF([PM RPK]<>0,DIVIDE([CM RPK],[PM RPK])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM RPK (A)': month-over-month growth (CM RPK (A)/PM RPK (A) - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM RPK (A)' = IF([PM RPK (A)]<>0,DIVIDE([CM RPK (A)],[PM RPK (A)])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Comp Flights': month-over-month growth (CM No of Comp Flights/PM No of Comp Flights - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Comp Flights' = IF([PM No of Comp Flights]<>0,DIVIDE([CM No of Comp Flights],[PM No of Comp Flights])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM On-Time Perf': month-over-month growth (CM Count On-Time Perf/PM Count On-Time Perf - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM On-Time Perf' = IF([PM Count On-Time Perf]<>0,DIVIDE([CM Count On-Time Perf],[PM Count On-Time Perf])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Tableau 'Pos MoM Avg. CSAT': month-over-month growth (CM Avg. CSAT/PM Avg. CSAT - 1); signed value in both directions (BLANK only when there is no prior-month baseline).
	measure 'Pos MoM Avg. CSAT' = IF([PM Avg. CSAT]<>0,DIVIDE([CM Avg. CSAT],[PM Avg. CSAT])-1)
		formatString: 0.0%
		displayFolder: MoM Growth (Positive)

	/// Prior-month month number derived from the Month parameter (wraps 1->12).
	measure 'PM Month Value' = IF([Month Parameter Value]=1,12,[Month Parameter Value]-1)
		formatString: #,##0
		displayFolder: Parameters
		isHidden

	/// Prior-month year derived from the Year/Month parameters (rolls back at January).
	measure 'PM Year Value' = IF([Month Parameter Value]=1,[Year Parameter Value]-1,[Year Parameter Value])
		formatString: #,##0
		displayFolder: Parameters
		isHidden

	/// Tableau 'Date From Params': MAKEDATE(Year Parameter, Month Parameter, 1) - first day of the selected month.
	measure 'Date From Params Value' = DATE([Year Parameter Value],[Month Parameter Value],1)
		formatString: Short Date
		displayFolder: Parameters
		isHidden

	/// Tableau 'Selected Region' = current Origin Region parameter value.
	measure 'Selected Region' = [Region Parameter Value]
		displayFolder: Parameters

	/// Tableau 'Selected Airline' = current Airline Name parameter value.
	measure 'Selected Airline' = [Airline Parameter Value]
		displayFolder: Parameters

	/// Tableau 'Selected Aircraft Type' = current Aircraft Type parameter value.
	measure 'Selected Aircraft Type' = [Aircraft Parameter Value]
		displayFolder: Parameters

	/// Tableau 'Colour': highlights the month matching the Month parameter (assumes visual grouped by Date[Month Number]).
	measure 'Colour' = IF([Month Parameter Value]=SELECTEDVALUE('Date'[Month Number]),"Month","Others")
		displayFolder: Report Helpers

	/// Tableau 'Year Colour': highlights the year matching the Year parameter (assumes visual grouped by Date[Year]).
	measure 'Year Colour' = IF([Year Parameter Value]=SELECTEDVALUE('Date'[Year]),"Year","Others")
		displayFolder: Report Helpers

	/// Tableau 'Bar Colours': highlights the selected month bar (assumes visual grouped by Date[Month Start]).
	measure 'Bar Colours' = IF(SELECTEDVALUE('Date'[Month Start])=[Date From Params Value],"Selected Month","Others")
		displayFolder: Report Helpers

	/// Tableau 'Airline Bar Colours': highlights the selected month for the selected airline (assumes month+airline in context).
	measure 'Airline Bar Colours' = IF(SELECTEDVALUE('Date'[Month Start])=[Date From Params Value]&&SELECTEDVALUE('Flight Activity'[Airline Name])=[Airline Parameter Value],"Selected Month","Others")
		displayFolder: Report Helpers

	/// Tableau 'Today' = TODAY().
	measure 'Today' = TODAY()
		formatString: Short Date
		displayFolder: Report Helpers

	/// Tableau 'Header size' constant (180).
	measure 'Header size' = 180
		formatString: #,##0
		displayFolder: Report Helpers

	/// Convenience replacement for Tableau dimension 'CM Main Destinations' (a parameter-equality projection). Put Destination City on the visual + this measure to rank top CM destinations; region filter applies to Origin Region (top destinations for flights DEPARTING the selected region, matching the Origin Region semantics used across the rest of the dashboard - validator found Destination Region here was ~2x off vs Tableau).
	measure 'CM Comp Flights to Destination' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_month_parameter_value = [Month Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Month]=_m_month_parameter_value,'Flight Activity'[Completed Flights]=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Current Month (CM)

