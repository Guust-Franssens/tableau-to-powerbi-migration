	measure 'CM RPK (A)' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_month_parameter_value = [Month Parameter Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUMX('Flight Activity','Flight Activity'[Passengers Carried]*'Flight Activity'[Distance Km]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Month]=_m_month_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Current Month (CM)

	/// Tableau 'CM Total Revenue' measure. Total Revenue over CM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'CM Total Revenue' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_month_parameter_value = [Month Parameter Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Total Revenue Usd]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Month]=_m_month_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: \$#,##0
		displayFolder: Current Month (CM)

	/// Tableau 'PM All Flights' measure. All Flights over PM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM All Flights' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Avg. CSAT' measure. Avg. CSAT over PM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Avg. CSAT' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(AVERAGE('Flight Activity'[Customer Satisfaction Score]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: 0.00
		displayFolder: Prior Month (PM)

	/// Tableau 'PM CTK' measure. CTK over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM CTK' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUMX('Flight Activity','Flight Activity'[Cargo Carried Kg]*'Flight Activity'[Distance Km])/1000,'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Cargo Load Factor' measure. Cargo Load Factor over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Cargo Load Factor' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(AVERAGE('Flight Activity'[Cargo Load Factor]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: 0.0%
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Costs' measure. Costs over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Costs' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Total Costs Usd]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: \$#,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Count On-Time Perf' measure. Count On-Time Perf over PM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Count On-Time Perf' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[On Time Performance]=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
		displayFolder: Prior Month (PM)

	/// Tableau 'PM Freight Tonnes' measure. Freight Tonnes over PM period, airline = [Airline Parameter Value], region-restricted via the Origin Region parameter (Global = show all).
	measure 'PM Freight Tonnes' = VAR _m_pm_year_value = [PM Year Value] VAR _m_pm_month_value = [PM Month Value] VAR _m_airline_parameter_value = [Airline Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(SUM('Flight Activity'[Cargo Carried Kg])/1000,'Flight Activity'[Year]=_m_pm_year_value,'Flight Activity'[Month]=_m_pm_month_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Airline Name]=_m_airline_parameter_value,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
