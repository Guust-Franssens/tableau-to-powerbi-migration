	column 'Aircraft Name' = IF(LEFT('Flight Activity'[Aircraft Type],1)="A","Airbus","Boeing")
		dataType: string
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Flight Activity' = m
		mode: import
		source =
			let
				Source = Csv.Document(File.Contents(DataFolder & "ds.airline_alliance_performance_2022_2025_1.csv"),[Delimiter=",", Columns=70, Encoding=65001, QuoteStyle=QuoteStyle.Csv]),
				#"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
				#"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"date", type date}, {"year", Int64.Type}, {"month", Int64.Type}, {"quarter", type text}, {"day_of_week", type text}, {"airline_code", type text}, {"airline_name", type text}, {"hub_airport", type text}, {"hub_city", type text}, {"hub_country", type text}, {"flight_id", type text}, {"aircraft_type", type text}, {"route_category", type text}, {"origin_airport", type text}, {"origin_city", type text}, {"origin_country", type text}, {"origin_region", type text}, {"origin_latitude", type number}, {"origin_longitude", type number}, {"destination_airport", type text}, {"destination_city", type text}, {"destination_country", type text}, {"destination_region", type text}, {"destination_latitude", type number}, {"destination_longitude", type number}, {"route", type text}, {"is_hub_flight", Int64.Type}, {"is_international", Int64.Type}, {"is_intercontinental", Int64.Type}, {"scheduled_flights", Int64.Type}, {"completed_flights", Int64.Type}, {"cancelled_flights", Int64.Type}, {"distance_km", Int64.Type}, {"flight_duration_hours", type number}, {"aircraft_capacity", Int64.Type}, {"passengers_carried", Int64.Type}, {"load_factor", type number}, {"average_fare_usd", type number}, {"passenger_revenue_usd", type number}, {"cargo_capacity_kg", Int64.Type}, {"cargo_carried_kg", type number}, {"cargo_load_factor", type number}, {"cargo_revenue_usd", type number}, {"total_revenue_usd", type number}, {"fuel_cost_usd", type number}, {"crew_cost_usd", type number}, {"maintenance_cost_usd", type number}, {"airport_fees_usd", Int64.Type}, {"other_costs_usd", type number}, {"total_costs_usd", type number}, {"operating_profit_usd", type number}, {"profit_margin_pct", type number}, {"on_time_performance", Int64.Type}, {"delay_minutes", Int64.Type}, {"fuel_consumed_kg", type number}, {"fuel_efficiency_kg_per_100km", type number}, {"customer_satisfaction_score", type number}, {"total_baggage", Int64.Type}, {"mishandled_baggage", Int64.Type}, {"baggage_handling_rate", type number}, {"co2_emissions_kg", type number}, {"co2_per_passenger_kg", type number}, {"fuel_price_per_unit", type number}, {"covid_impact_factor", type number}, {"seasonal_factor_passenger", type number}, {"seasonal_factor_cargo", type number}, {"revenue_per_passenger", type number}, {"cost_per_passenger", type number}, {"revenue_per_km", type number}, {"cost_per_km", type number}}, "en-US")
			in
				#"Changed Type"

	annotation PBI_ResultType = Table
