		formatString: #,##0
		displayFolder: Current Month (CM)

	/// Tableau 'CM No of Mishandled Baggage' measure. No of Mishandled Baggage over CM period, all airlines (region-wide), region-restricted via the Origin Region parameter (Global = show all).
	measure 'CM No of Mishandled Baggage' = VAR _m_year_parameter_value = [Year Parameter Value] VAR _m_month_parameter_value = [Month Parameter Value] VAR _m_region_parameter_value = [Region Parameter Value] RETURN CALCULATE(DISTINCTCOUNT('Flight Activity'[Flight Id]),'Flight Activity'[Year]=_m_year_parameter_value,'Flight Activity'[Month]=_m_month_parameter_value,'Flight Activity'[Completed Flights]=1,'Flight Activity'[Mishandled Baggage]>=1,FILTER(ALL('Flight Activity'[Origin Region]),_m_region_parameter_value="Global"||'Flight Activity'[Origin Region]=_m_region_parameter_value))
		formatString: #,##0
