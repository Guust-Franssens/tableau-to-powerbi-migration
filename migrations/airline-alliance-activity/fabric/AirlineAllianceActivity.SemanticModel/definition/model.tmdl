model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Flight Activity", "Date", "Year Parameter", "Month Parameter", "Region Parameter", "Airline Parameter", "Aircraft Type Parameter", "Airline Code Parameter", "Guidelines Parameter", "DataFolder"]

annotation __PBI_TimeIntelligenceEnabled = 0

ref table 'Flight Activity'
ref table 'Date'
ref table 'Year Parameter'
ref table 'Month Parameter'
ref table 'Region Parameter'
ref table 'Airline Parameter'
ref table 'Aircraft Type Parameter'
ref table 'Airline Code Parameter'
ref table 'Guidelines Parameter'
