model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Top 100 IPOs","Securities","Latest Tall SP Data","Stocks (DJIA)","Investment Amount","Dollar Amount","Date Detail","DataFolder"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table 'Top 100 IPOs'
ref table Securities
ref table 'Latest Tall SP Data'
ref table 'Stocks (DJIA)'
ref table 'Investment Amount'
ref table 'Dollar Amount'
ref table 'Date Detail'

