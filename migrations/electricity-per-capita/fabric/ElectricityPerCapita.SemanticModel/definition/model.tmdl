model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Per Capita FNR","Tree","Pivoted","Elec Generation","By Source","Year","Show chart as","View data for","Year Slider","DataFolder"]

annotation __PBI_TimeIntelligenceEnabled = 0

ref table 'Per Capita FNR'
ref table 'Tree'
ref table 'Pivoted'
ref table 'Elec Generation'
ref table 'By Source'
ref table 'Year'
ref table 'Show chart as'
ref table 'View data for'
ref table 'Year Slider'

