	/// Tableau [% of Fossil Fuel Electricity] = FF/(FF+Nuc+Ren) row-level ratio (vestigial source).
	column '% of Fossil Fuel Electricity' = DIVIDE('By Source'[Fossil fuel electricity per capita - kWh], 'By Source'[Fossil fuel electricity per capita - kWh] + 'By Source'[Nuclear electricity per capita - kWh] + 'By Source'[Renewable electricity per capita - kWh])
		dataType: double
		lineageTag: f0c0cef2-c42f-58fc-9db3-75bdbcb26032
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Tableau [% of Nuclear Electricity] = Nuc/(FF+Nuc+Ren) (vestigial).
	column '% of Nuclear Electricity' = DIVIDE('By Source'[Nuclear electricity per capita - kWh], 'By Source'[Fossil fuel electricity per capita - kWh] + 'By Source'[Nuclear electricity per capita - kWh] + 'By Source'[Renewable electricity per capita - kWh])
		dataType: double
		lineageTag: c5768374-fdfd-59f6-ba93-ed5163370748
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Tableau [% of Renewable Electricity] = Ren/(FF+Nuc+Ren) (vestigial).
	column '% of Renewable Electricity' = DIVIDE('By Source'[Renewable electricity per capita - kWh], 'By Source'[Fossil fuel electricity per capita - kWh] + 'By Source'[Nuclear electricity per capita - kWh] + 'By Source'[Renewable electricity per capita - kWh])
		dataType: double
		lineageTag: 4c7fc88f-7db9-507c-9930-2fb3257194ad
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Tableau [Year for label] = IF [Year]=2020 THEN [Year] END (vestigial).
	column 'Year for label' = IF('By Source'[Year] = 2020, 'By Source'[Year])
		dataType: int64
		lineageTag: 7500f702-4282-5d0f-b1e8-e47d95a80fb6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

