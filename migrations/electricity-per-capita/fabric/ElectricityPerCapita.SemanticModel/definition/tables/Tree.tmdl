		dataType: double
		lineageTag: 66976108-212a-5a05-8b0a-b57a4cd47584
		summarizeBy: none
		sourceColumn: y

		annotation SummarizationSetBy = Automatic

	column 'Usage ration'
		dataType: double
		lineageTag: 4145479f-b7f1-557a-bea4-d7367774ff72
		summarizeBy: none
		sourceColumn: Usage ration

		annotation SummarizationSetBy = Automatic

	column 'Id'
		dataType: string
		lineageTag: 7f16e267-2c24-51bb-80be-f9ba22d8f2e8
		summarizeBy: none
