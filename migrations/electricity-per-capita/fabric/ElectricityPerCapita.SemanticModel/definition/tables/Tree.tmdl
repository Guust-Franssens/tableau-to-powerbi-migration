/// Sankey/treemap GEOMETRY rows exported from the 'tree' source (3,320 rows: 3,100 link + 216 node + 4 border). Pure layout coordinates; the consumption columns the tree source also exposes live in 'Elec Generation' (joined child=Entity). The Sankey itself is a HIGH capability gap - see limitations.
table 'Tree'
	lineageTag: 726fceef-4089-5235-8956-a4f388e4426a

	/// Tableau [X Axis - Bar chart] = MIN(0.0): a constant 0 axis anchor for the small-multiple bar layout. Kept as a 0 measure.
	measure 'X Axis Bar chart' = 0
		formatString: 0.0
		lineageTag: 36dbed5c-ee66-5343-b525-44fad6cf94f6
		displayFolder: Axis anchors

	/// Tableau [X Axis - Rank] = MIN(0.0): constant 0 axis anchor.
	measure 'X Axis Rank' = 0
		formatString: 0.0
		lineageTag: 018bb1bb-5d3e-5e58-8a63-fbb362f0fa77
		displayFolder: Axis anchors

	/// Tableau [X Axis - Text] = MIN(0.0): constant 0 axis anchor.
	measure 'X Axis Text' = 0
		formatString: 0.0
		lineageTag: 4948be10-752b-5e26-a7ca-9e6d8222bc15
		displayFolder: Axis anchors

	column 'Index'
		dataType: int64
		lineageTag: 44034268-6df2-5dbc-97e6-20b5b31a692d
		summarizeBy: none
		sourceColumn: index

		annotation SummarizationSetBy = Automatic

	column 'Path'
