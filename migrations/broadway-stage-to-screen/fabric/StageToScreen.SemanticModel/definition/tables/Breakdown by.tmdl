		summarizeBy: none
		sourceColumn: [Value3]

		annotation SummarizationSetBy = Automatic

	partition 'Breakdown by' = calculated
		mode: import
		source = {("Award", NAMEOF('3 Accolades'[Award]), 0), ("Category", NAMEOF('3 Accolades'[Category (group)]), 1)}

	annotation PBI_ResultType = Table
