		sourceColumn: [Value1]
		sortByColumn: 'Breakdown by Order'

		annotation SummarizationSetBy = Automatic

	column 'Breakdown by Fields'
		isHidden
		lineageTag: 48dd1a78-64cd-546a-ac9a-33571189e249
		summarizeBy: none
		sourceColumn: [Value2]

