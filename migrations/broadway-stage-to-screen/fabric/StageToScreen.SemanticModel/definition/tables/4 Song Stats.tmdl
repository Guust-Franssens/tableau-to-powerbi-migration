/// Song/track-level fact (6811 rows), keys [Film]/[Original], Type in {Theater,Movie}. Already carries the melted 'Pivot Field Names'/'Pivot Field Values' audio-feature columns (no Power Query unpivot needed - the reshape is materialized in the extract).
table '4 Song Stats'
	lineageTag: aac195c6-56e6-5a40-9fbc-32bfa365eef0

	/// Tableau [Track Cnt] = COUNTD([Track ID]).
	measure 'Track Cnt' = DISTINCTCOUNT('4 Song Stats'[Track ID])
		formatString: #,##0
		lineageTag: a006778b-49ce-50d2-926a-cfbb65ea4e13

	/// Tableau IIF(MIN([Type]='Theater'),[Track Cnt],NULL) - the MIN()-boolean all-rows-Theater guard is simplified to a direct Type='Theater' filter (equivalent when the viz splits by Type).
	measure 'Track Cnt, Theater only' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), '4 Song Stats'[Type] = "Theater")
		formatString: #,##0
		lineageTag: 8c45ec52-2538-542a-89ae-480b5b3ebf7a

	/// Tableau IIF(MIN([Type]='Movie'),[Track Cnt],NULL) -> direct Type='Movie' filter (same simplification as Theater only).
	measure 'Track Cnt, Movie only' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), '4 Song Stats'[Type] = "Movie")
		formatString: #,##0
		lineageTag: b07a0062-cc8f-5847-9f75-cd6eb4ee2827

	/// Conditional FIXED LOD {FIXED [Film]: MIN(IIF([Type]='Theater',[Album Popularity ( %)],NULL))} -> CALCULATE(MIN,...,ALLEXCEPT([Film]),Type='Theater'). GROUND-TRUTHED.
	measure 'Album Popularity, Theater' = CALCULATE(MIN('4 Song Stats'[Album Popularity ( %)]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Film]), '4 Song Stats'[Type] = "Theater")
		formatString: 0
		lineageTag: 2fcd583a-77de-5761-bbc3-f0dd81d2a026

	/// Conditional FIXED LOD {FIXED [Film]: MIN(IIF([Type]='Movie',...))}. GROUND-TRUTHED.
	measure 'Album Popularity, Movie' = CALCULATE(MIN('4 Song Stats'[Album Popularity ( %)]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Film]), '4 Song Stats'[Type] = "Movie")
		formatString: 0
		lineageTag: 65d47f65-3995-5969-9c39-5a8c198c846e

	/// Tableau [Popularity Diff] = [Album Popularity, Movie] - [Album Popularity, Theater].
	measure 'Popularity Diff' = [Album Popularity, Movie] - [Album Popularity, Theater]
		formatString: 0
		lineageTag: 7e341dc1-eb96-5a87-8f03-579bff144fef

	/// Conditional FIXED LOD {FIXED [Original]: COUNTD(IIF([Type]='Movie',[Track ID],NULL))}. GROUND-TRUTHED.
	measure 'Track Cnt, Movie Album Total' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Original]), '4 Song Stats'[Type] = "Movie")
		formatString: #,##0
		lineageTag: 19057ee5-9834-5dac-8345-95db51a3f1fe

	/// Conditional FIXED LOD {FIXED [Original]: COUNTD(IIF([Type]='Theater',...))}. GROUND-TRUTHED.
	measure 'Track Cnt, Theater Album Total' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Original]), '4 Song Stats'[Type] = "Theater")
		formatString: #,##0
		lineageTag: 274972d9-eb91-5a36-8b8c-5313e0477155

	/// Conditional FIXED LOD {FIXED [Original],[Pivot Field Names],[Song Stat Value (bin)]: COUNTD(IIF([Type]='Movie',...))}.
	measure 'Track Cnt, Movie Album + Stat' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Original], '4 Song Stats'[Pivot Field Names], '4 Song Stats'[Song Stat Value (bin)]), '4 Song Stats'[Type] = "Movie")
		formatString: #,##0
		lineageTag: 4edfde32-72e7-5ed9-96f1-82ac4ee56008

	/// Conditional FIXED LOD {FIXED [Original],[Pivot Field Names],[Song Stat Value (bin)]: COUNTD(IIF([Type]='Theater',...))}.
	measure 'Track Cnt, Theater Album + Stat' = CALCULATE(DISTINCTCOUNT('4 Song Stats'[Track ID]), ALLEXCEPT('4 Song Stats', '4 Song Stats'[Original], '4 Song Stats'[Pivot Field Names], '4 Song Stats'[Song Stat Value (bin)]), '4 Song Stats'[Type] = "Theater")
		formatString: #,##0
		lineageTag: 62710448-7b20-55f3-86f5-e16ec09e84b0

	/// Tableau [Track Cnt, Movie Album + Stat] / [Track Cnt, Movie Album Total].
	measure 'Track Cnt%, Movie Album + Stat' = DIVIDE([Track Cnt, Movie Album + Stat], [Track Cnt, Movie Album Total])
		formatString: 0.0%
		lineageTag: 11febfa5-2c2c-59bc-9b9e-1b3e44eea913

	/// Tableau [Track Cnt, Theater Album + Stat] / [Track Cnt, Theater Album Total].
	measure 'Track Cnt%, Theater Album + Stat' = DIVIDE([Track Cnt, Theater Album + Stat], [Track Cnt, Theater Album Total])
		formatString: 0.0%
		lineageTag: e07f7265-a4a0-5ac4-a96b-bb1a9f5110f8

