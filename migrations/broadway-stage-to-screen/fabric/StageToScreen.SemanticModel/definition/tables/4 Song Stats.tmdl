	/// Tableau [Type (Cont)] = FLOAT(IIF(Type='Theater',1,2)). Continuous 1.0/2.0 encoding of Type.
	column 'Type (Cont)' = IF('4 Song Stats'[Type] = "Theater", 1, 2)
		dataType: double
		lineageTag: 58b2f2ee-e7f7-5b0f-9fa0-0e89bc6a0553
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau bin on [Pivot Field Values], size 0.1, peg 0 -> FLOOR to nearest 0.1. +1e-7 epsilon guards FP boundary (values are <=3 decimals); ROUND(,1) cleans FP noise.
	column 'Song Stat Value (bin)' = ROUND(FLOOR('4 Song Stats'[Pivot Field Values] + 0.0000001, 0.1), 1)
		dataType: double
		formatString: 0.0
		lineageTag: ee9e0811-3fdb-5f72-9056-3783680dcfa2
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	/// Tableau group [Film (Album Pop Highlight)] on [Film] (default 'Other'). Faithful member->bucket SWITCH.
	column 'Film (Album Pop Highlight)' = SWITCH(TRUE(), '4 Song Stats'[Film] IN {"Chicago", "Mamma Mia!", "Mamma Mia! Here We Go Again", "tick, tick... BOOM!"}, "Chicago, Mamma Mia!, Mamma Mia! Here We Go Again and 1 more", '4 Song Stats'[Film] = "Dear Evan Hansen", "Dear Evan Hansen", "Other")
		dataType: string
		lineageTag: 87c20da1-283d-5a1e-b501-aab23594a3c8
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

